#!/bin/sh
set -euf
top="$(git rev-parse --show-toplevel)"
for dir in $(find "$top/components" -type d -depth 1 | sort); do
     name=$(basename "$dir")
     has_claude_file=$([ -f "$dir/CLAUDE.md" ] && echo "true" || echo "false")
     has_index_file=$([ -f "$dir/index.md" ] && echo "true" || echo "false")
     has_component_mardown_file=$([ -f "$dir"*.md ] && echo "true" || echo "false")
     has_component_test_file=$([ -f "$dir"*.test.ts ] && echo "true" || echo "false")
     echo "$name|$has_claude_file|$has_index_file|$has_component_markdown_file|$has_component_test_file"
done
