@page "/task-management"

<h1>Task Management</h1>

<section class="section">
    <Badge Type="success">@completedCount done</Badge>
    <Badge Type="default">@(tasks.Count - completedCount) remaining</Badge>
    <Progress Label="Overall completion" Value="@percent.ToString()" Max="100" />
    <p>@percent% complete</p>
</section>

<section class="section">
    <TextInput Label="New task" Value="@newTitle" ValueChanged="v => newTitle = v" />
    <Button @onclick="AddTask">Add Task</Button>
</section>

<section class="section">
    <CheckboxInput Label="Show completed tasks" Checked="@showCompleted" CheckedChanged="v => showCompleted = v" />
</section>

<TaskList Label="Project tasks">
    @foreach (var task in VisibleTasks)
    {
        var t = task;
        <TaskListItem Label="@t.Title" Checked="@t.Done"
                      CheckedChanged="v => ToggleTask(t.Id, v)" />
    }
</TaskList>

<section class="section">
    <h2>Priority Overview</h2>
    <Badge Type="error">@tasks.Count(t => t.Priority == "high") high</Badge>
    <Badge Type="warning">@tasks.Count(t => t.Priority == "medium") medium</Badge>
    <Badge Type="info">@tasks.Count(t => t.Priority == "low") low</Badge>
</section>

@code {
    private class TaskItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public bool Done { get; set; }
        public string Priority { get; set; } = "medium";
    }

    private List<TaskItem> tasks = new()
    {
        new() { Id = 1, Title = "Set up project repository", Done = true, Priority = "high" },
        new() { Id = 2, Title = "Draft API specification", Done = true, Priority = "high" },
        new() { Id = 3, Title = "Design database schema", Done = false, Priority = "medium" },
        new() { Id = 4, Title = "Write integration tests", Done = false, Priority = "medium" },
        new() { Id = 5, Title = "Prepare deployment scripts", Done = false, Priority = "low" },
    };

    private string newTitle = "";
    private bool showCompleted = true;

    private int completedCount => tasks.Count(t => t.Done);
    private int percent => tasks.Count > 0 ? (int)Math.Round((double)completedCount / tasks.Count * 100) : 0;

    private IEnumerable<TaskItem> VisibleTasks =>
        showCompleted ? tasks : tasks.Where(t => !t.Done);

    private void AddTask()
    {
        if (!string.IsNullOrWhiteSpace(newTitle))
        {
            tasks.Add(new TaskItem
            {
                Id = (int)DateTimeOffset.UtcNow.ToUnixTimeMilliseconds(),
                Title = newTitle.Trim(),
                Done = false,
                Priority = "medium"
            });
            newTitle = "";
        }
    }

    private void ToggleTask(int id, bool done)
    {
        var task = tasks.FirstOrDefault(t => t.Id == id);
        if (task != null)
            task.Done = done;
    }
}
